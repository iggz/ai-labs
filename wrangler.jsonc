{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai-labs",
  "compatibility_date": "2026-06-19",
  "main": "src/index.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "web/dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "ilovetoridemybicycle.com/ai-labs*",
      "zone_id": "0a3a58000de0c118405d1cea7f5797f8"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "DEBUG_LOGS",
      "id": "5f14c97e465a45bdaad5df8ae3fb6931"
    }
  ]
}
