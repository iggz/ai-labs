# Protocol routing is handled by PROTOCOL_HOSTS in cvApi.js.
# Do NOT set VITE_CV_API_URL here — it overrides all protocol routing,
# including yolo → Mac. Leave it unset so the routing table is used:
#   dml    → https://api.ilovetoridemybicycle.com        (PC Tower, AMD DirectML — default)
#   yolo   → https://api-mac.ilovetoridemybicycle.com    (Mac, CoreML / Metal)
#   cuda   → https://api-cuda.ilovetoridemybicycle.com   (Laptop, NVIDIA CUDA — coming soon)
#   opencv → https://api.ilovetoridemybicycle.com        (PC Tower, OpenCV DNN fallback)
