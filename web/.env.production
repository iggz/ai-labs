# Protocol routing is handled by PROTOCOL_HOSTS in cvApi.js.
# Do NOT set VITE_CV_API_URL here — it overrides all protocol routing,
# including yolo → Mac. Leave it unset so the routing table is used:
#   yolo   → https://api-mac.ilovetoridemybicycle.com  (Mac / CoreML)
#   dml    → https://api.ilovetoridemybicycle.com      (PC / DirectML)
#   opencv → https://api.ilovetoridemybicycle.com      (PC / OpenCV)
